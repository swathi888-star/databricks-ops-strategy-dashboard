{
  "datasets": [
    {
      "name": "747cd27a",
      "displayName": "Regional Revenue",
      "queryLines": [
        "WITH RegionalTotals AS (\r\n",
        "    SELECT \r\n",
        "        l.region,\r\n",
        "        ROUND(SUM(f.order_value), 2) AS total_region_revenue\r\n",
        "    FROM my_project_db.gold_sales_fact f\r\n",
        "    JOIN my_project_db.gold_dim_leads l ON f.lead_id = l.lead_id\r\n",
        "    WHERE YEAR(f.order_in_date) = :selected_year\r\n",
        "    GROUP BY l.region\r\n",
        "    ORDER BY total_region_revenue DESC\r\n",
        "    LIMIT 5\r\n",
        "),\r\n",
        "DivisionPerformance AS (\r\n",
        "    SELECT \r\n",
        "        l.region,\r\n",
        "        p.division,\r\n",
        "        ROUND(SUM(f.order_value), 2) AS division_revenue,\r\n",
        "        ROW_NUMBER() OVER(PARTITION BY l.region ORDER BY SUM(f.order_value) DESC) as div_rank\r\n",
        "    FROM my_project_db.gold_sales_fact f\r\n",
        "    JOIN my_project_db.gold_dim_leads l ON f.lead_id = l.lead_id\r\n",
        "    JOIN my_project_db.gold_dim_products p ON f.invt_id = p.invt_id\r\n",
        "    WHERE YEAR(f.order_in_date) = :selected_year\r\n",
        "      AND l.region IN (SELECT region FROM RegionalTotals)\r\n",
        "    GROUP BY l.region, p.division\r\n",
        ")\r\n",
        "SELECT \r\n",
        "    rt.region,\r\n",
        "    rt.total_region_revenue,\r\n",
        "    dp.division AS top_division,\r\n",
        "    dp.division_revenue\r\n",
        "FROM RegionalTotals rt\r\n",
        "JOIN DivisionPerformance dp ON rt.region = dp.region\r\n",
        "WHERE dp.div_rank = 1\r\n",
        "ORDER BY rt.total_region_revenue DESC;"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "selected_year",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "2020"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4d1e9136",
      "displayName": "Operation_bottleneck",
      "queryLines": [
        "WITH DelayCounts AS (\r\n",
        "    SELECT \r\n",
        "        p.division,\r\n",
        "        f.reason_name, \r\n",
        "        COUNT(*) as occurrence_count\r\n",
        "    FROM my_project_db.gold_sales_fact f\r\n",
        "    JOIN my_project_db.gold_dim_products p ON f.invt_id = p.invt_id\r\n",
        "    -- Added the year filter here\r\n",
        "    WHERE f.reason_name IS NOT NULL \r\n",
        "      AND YEAR(f.order_in_date) = :selected_year\r\n",
        "    GROUP BY p.division, f.reason_name\r\n",
        "),\r\n",
        "RankedDelays AS (\r\n",
        "    SELECT \r\n",
        "        division,\r\n",
        "        reason_name,\r\n",
        "        occurrence_count,\r\n",
        "        ROW_NUMBER() OVER(PARTITION BY division ORDER BY occurrence_count DESC) as rank\r\n",
        "    FROM DelayCounts\r\n",
        ")\r\n",
        "SELECT \r\n",
        "    division,\r\n",
        "    reason_name as most_common_bottleneck,\r\n",
        "    occurrence_count\r\n",
        "FROM RankedDelays\r\n",
        "WHERE rank = 1;"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "selected_year",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "2024"
                }
              ]
            }
          }
        }
      ],
      "catalog": "workspace",
      "schema": "my_project_db"
    },
    {
      "name": "db55752a",
      "displayName": "Product_aging",
      "queryLines": [
        "SELECT \r\n",
        "    p.product_sku,\r\n",
        "    p.division,\r\n",
        "    YEAR(f.warranty_date) - 2 AS import_year,\r\n",
        "    f.warranty_date,\r\n",
        "    SUM(f.inventory_qty - f.order_qty) AS total_unsold_qty,\r\n",
        "    ROUND(SUM((f.inventory_qty - f.order_qty) * f.purchase_cost), 2) AS total_aging_value\r\n",
        "FROM my_project_db.gold_sales_fact f\r\n",
        "JOIN my_project_db.gold_dim_products p ON f.invt_id = p.invt_id\r\n",
        "WHERE f.warranty_date < date_sub(CURRENT_DATE(), :aging_days)\r\n",
        "  AND (f.inventory_qty - f.order_qty) > 0\r\n",
        "  -- Added this filter to sync with your dashboard's global slicer\r\n",
        "  AND YEAR(f.warranty_date) = :selected_year\r\n",
        "GROUP BY \r\n",
        "    p.product_sku, \r\n",
        "    p.division, \r\n",
        "    f.warranty_date\r\n",
        "QUALIFY ROW_NUMBER() OVER(PARTITION BY p.product_sku ORDER BY f.warranty_date DESC) = 1\r\n",
        "ORDER BY total_aging_value DESC\r\n",
        "LIMIT 5;"
      ],
      "parameters": [
        {
          "displayName": "Days",
          "keyword": "aging_days",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "30"
                }
              ]
            }
          }
        },
        {
          "displayName": "Year",
          "keyword": "selected_year",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "2024"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "199a4a46",
      "displayName": "Source_conversion",
      "queryLines": [
        "WITH SourceConversions AS (\r\n",
        "    SELECT \r\n",
        "        p.division,\r\n",
        "        l.source_name,\r\n",
        "        COUNT(f.order_id) as total_conversions\r\n",
        "    FROM my_project_db.gold_sales_fact f\r\n",
        "    JOIN my_project_db.gold_dim_products p ON f.invt_id = p.invt_id\r\n",
        "    JOIN my_project_db.gold_dim_leads l ON f.lead_id = l.lead_id\r\n",
        "    -- This filter ensures the logic applies only to the selected year\r\n",
        "    WHERE YEAR(f.order_in_date) = :selected_year\r\n",
        "    GROUP BY p.division, l.source_name\r\n",
        "),\r\n",
        "RankedSources AS (\r\n",
        "    SELECT \r\n",
        "        division,\r\n",
        "        source_name,\r\n",
        "        total_conversions,\r\n",
        "        ROW_NUMBER() OVER(PARTITION BY division ORDER BY total_conversions DESC) as rank\r\n",
        "    FROM SourceConversions\r\n",
        ")\r\n",
        "SELECT \r\n",
        "    division,\r\n",
        "    source_name,\r\n",
        "    total_conversions\r\n",
        "FROM RankedSources \r\n",
        "WHERE rank <= 3\r\n",
        "ORDER BY division, total_conversions DESC;"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "selected_year",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "2024"
                }
              ]
            }
          }
        }
      ]
    }
  ],
